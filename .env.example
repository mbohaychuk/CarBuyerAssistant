# --- Required (no useful default) ---
# OpenAI API key with access to OPENAI_MODEL below.
OPENAI_API_KEY=
# Discord bot token from https://discord.com/developers/applications.
DISCORD_BOT_TOKEN=
# Discord server (guild) ID. Right-click the server icon in Discord and
# choose "Copy Server ID" with Developer Mode enabled. Required ONLY when
# DISCORD_CHANNELS below uses channel names; ignored when it uses IDs.
DISCORD_GUILD_ID=
# JSON object mapping ChannelKey -> Discord channel name OR channel id.
# ChannelKey values are defined in src/carbuyer/apps/bot/channels.py:
#   wants, auction_closing, auction_watch, vision_updates, system_health,
#   needs_plugin
# Missing keys make the corresponding notifications silently no-op (the
# notifier logs a warning but otherwise continues).
#
# Names are resolved to IDs once at notifier startup via the Discord REST
# API. To list the channels in your guild and verify naming, run:
#     python -m carbuyer.tools.list_channels
DISCORD_CHANNELS={"wants":"car-wants","auction_closing":"car-closing-soon","needs_plugin":"car-system"}

# --- Database ---
# Phase 0 docker-compose binds host port 5433 (not 5432) to avoid collision
# with a host-native Postgres install.
DATABASE_URL=postgresql+psycopg://carbuyer:local@localhost:5433/carbuyer

# --- Common knobs (defaults shown; uncomment-edit to override) ---
HOME_PROVINCE=AB
LOG_LEVEL=INFO
INSTANT_DEAL_THRESHOLD=0.15
INSTANT_CLOSING_HOURS=24
QUIET_HOURS_START=22
QUIET_HOURS_END=8
# JSON list of provinces the HiBid discoverer scopes to.
HIBID_PROVINCES=["AB","BC","SK","MB"]
# JSON list of Craigslist regions (subdomains) the source searches; a want scoped
# to provinces only hits regions in those provinces.
CRAIGSLIST_REGIONS=["calgary","edmonton","vancouver","victoria","kelowna","winnipeg","toronto","ottawa","hamilton","kitchener","london","windsor","montreal","halifax","saskatoon","regina"]

# --- Optional Discord / OpenAI tunables ---
#OPENAI_MODEL=gpt-5-nano
#OPENAI_MAX_RETRIES=5
#OPENAI_REQUEST_TIMEOUT_S=60.0
#OPENAI_CONCURRENCY=4
# Reasoning-token effort for GPT-5 / o-series models. Our workload is
# extraction/classification — "low" cuts effective output cost 3-5x vs
# the SDK's default "medium". Set to None (literally the string "None"
# won't work — comment out instead) when using non-reasoning models like
# gpt-4o-mini, which reject this parameter.
#OPENAI_REASONING_EFFORT=low

# --- Enrichment / valuation / scoring versions ---
# Bump these when prompts/taxonomies/weights change so a backfill can re-pend
# stale rows: UPDATE auction_lots SET enrichment_status='pending'
# WHERE enrichment_version IS DISTINCT FROM '<new>'.
#ENRICHMENT_VERSION=v1
#SCORING_VERSION=v1

# --- Worker batch / retry knobs ---
#ENRICHMENT_BATCH_SIZE=20
#ENRICHMENT_MAX_ATTEMPTS=3
#VALUATION_BATCH_SIZE=30
#VALUATION_MAX_ATTEMPTS=3
# Lots whose RAW cumulative red-flag weight is at or below this are excluded
# from notifications regardless of price-deal score.
#EXCESSIVE_RED_FLAG_WEIGHT_THRESHOLD=-8

# --- Vision shortlist (nightly batcher) ---
#VISION_SHORTLIST_SCORE_THRESHOLD=0.10
#VISION_SHORTLIST_LIMIT=100

# --- HTTP ---
#HTTP_USER_AGENT=Mozilla/5.0 ...
# Private-source scraping (Kijiji): curl_cffi TLS-impersonation target +
# optional CA residential proxy. Anti-bot sites fingerprint the TLS handshake,
# so set a real proxy here for production listing fetches.
#HTTP_IMPERSONATE=chrome
#PROXY_URL=http://user:pass@ca-residential-proxy:port
# Opt-in NHTSA vPIC make/model normalization in the enricher (one keyless HTTP
# call per lot; best-effort). Aligns comp keys: "F150" -> "F-150".
#VPIC_NORMALIZATION_ENABLED=true
