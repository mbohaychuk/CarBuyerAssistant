# --- Required (no useful default) ---
# OpenAI API key with access to OPENAI_MODEL below.
OPENAI_API_KEY=
# Discord bot token from https://discord.com/developers/applications.
DISCORD_BOT_TOKEN=
# JSON object mapping ChannelKey -> Discord channel id. ChannelKey values are
# defined in src/carbuyer/apps/bot/channels.py: early_warning, hot_deals,
# watchlist, auction_closing, auction_watch, vision_updates, system_health,
# needs_plugin. Missing keys make the corresponding notifications silently
# no-op (the notifier logs a warning but otherwise continues).
DISCORD_CHANNELS={"early_warning":123,"hot_deals":456,"watchlist":789,"auction_closing":111,"needs_plugin":222}

# --- Database ---
# Phase 0 docker-compose binds host port 5433 (not 5432) to avoid collision
# with a host-native Postgres install.
DATABASE_URL=postgresql+psycopg://carbuyer:local@localhost:5433/carbuyer

# --- Common knobs (defaults shown; uncomment-edit to override) ---
HOME_PROVINCE=AB
LOG_LEVEL=INFO
NOTIFY_THRESHOLD=0.15
EARLY_WARNING_RARITY_THRESHOLD=2.0
EARLY_WARNING_MIN_HOURS_TO_CLOSE=48
RESCORE_IMPROVEMENT_THRESHOLD=0.05
QUIET_HOURS_START=22
QUIET_HOURS_END=8
QUIET_HOURS_OVERRIDE_SCORE=0.30
FLIP_MARGIN_MIN_CAD=1500
FLIP_MARGIN_PCT=0.10
# JSON list of provinces the HiBid discoverer scopes to.
HIBID_PROVINCES=["AB","BC","SK","MB"]

# --- Optional Discord / OpenAI tunables ---
#DISCORD_GUILD_ID=
#OPENAI_MODEL=gpt-4o-mini
#OPENAI_MAX_RETRIES=5
#OPENAI_REQUEST_TIMEOUT_S=60.0
#OPENAI_CONCURRENCY=4

# --- Enrichment / valuation / scoring versions ---
# Bump these when prompts/taxonomies/weights change so a backfill can re-pend
# stale rows: UPDATE auction_lots SET enrichment_status='pending'
# WHERE enrichment_version IS DISTINCT FROM '<new>'.
#ENRICHMENT_VERSION=v1
#SCORING_VERSION=v1

# --- Worker batch / retry knobs ---
#ENRICHMENT_BATCH_SIZE=20
#ENRICHMENT_MAX_ATTEMPTS=3
#VALUATION_BATCH_SIZE=30
#VALUATION_MAX_ATTEMPTS=3
# Lots whose RAW cumulative red-flag weight is at or below this are excluded
# from notifications regardless of price-deal score.
#EXCESSIVE_RED_FLAG_WEIGHT_THRESHOLD=-8

# --- Vision shortlist (nightly batcher) ---
#VISION_SHORTLIST_SCORE_THRESHOLD=0.10
#VISION_SHORTLIST_LIMIT=100

# --- HTTP ---
#HTTP_USER_AGENT=Mozilla/5.0 ...
